[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[core]
    pager = delta

[delta]
    navigate = true
    line-numbers = true
    side-by-side = true
    syntax-theme = Dracula

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[pager]
  branch = false
[init]
    defaultBranch = main
[push]
	autoSetupRemote = true
[user]
	# Never auto-guess identity from OS/hostname — require an explicit include.
	# Makes an unconfigured area (e.g. ~/Code/projects before the scaffold is filled)
	# fail loud instead of committing under an invented identity.
	useConfigOnly = true
[includeIf "gitdir:~/Code/liatrio/**"]
  path = ~/.gitconfig-liatrio
[includeIf "gitdir:~/Code/projects/**"]
  path = ~/.gitconfig-personal
